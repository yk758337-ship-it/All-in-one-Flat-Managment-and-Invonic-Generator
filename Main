    <script>
        // ========== FIXED LOGIN SYSTEM ==========
        
        // Database Class
        class EnterpriseDB {
            constructor() {
                this.STORAGE_KEY = 'flathub_enterprise_v2';
                this.load();
            }

            load() {
                try {
                    const data = localStorage.getItem(this.STORAGE_KEY);
                    if (data) {
                        this.data = JSON.parse(data);
                    } else {
                        this.initializeDefaultData();
                    }
                } catch (error) {
                    console.error('Error loading database:', error);
                    this.initializeDefaultData();
                }
            }

            initializeDefaultData() {
                this.data = {
                    admin: {
                        email: 'admin@flathub.com',
                        password: '8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918', // admin123
                        createdAt: new Date().toISOString(),
                        lastLogin: null
                    },
                    tenants: [],
                    payments: [],
                    settings: {
                        companyName: 'FlatHub Properties',
                        emailNotifications: true,
                        whatsAppNotifications: true,
                        smsNotifications: false
                    },
                    logs: [],
                    createdAt: new Date().toISOString()
                };
                this.save();
            }

            save() {
                try {
                    localStorage.setItem(this.STORAGE_KEY, JSON.stringify(this.data));
                } catch (error) {
                    console.error('Error saving database:', error);
                }
            }

            getAdmin() {
                return this.data.admin;
            }

            setAdmin(email, hashedPassword) {
                this.data.admin = {
                    email,
                    password: hashedPassword,
                    createdAt: new Date().toISOString(),
                    lastLogin: null
                };
                this.save();
            }

            updateLastLogin() {
                if (this.data.admin) {
                    this.data.admin.lastLogin = new Date().toISOString();
                    this.save();
                }
            }

            addLog(message, type = 'info') {
                const log = {
                    id: 'LOG_' + Date.now(),
                    message,
                    type,
                    timestamp: new Date().toISOString()
                };
                this.data.logs.push(log);
                this.save();
                
                if (this.data.logs.length > 100) {
                    this.data.logs = this.data.logs.slice(-100);
                }
            }

            getTenants() {
                return this.data.tenants || [];
            }

            getPayments() {
                return this.data.payments || [];
            }

            getTenant(id) {
                return this.data.tenants.find(t => t.id === id);
            }

            addTenant(tenantData) {
                const tenant = {
                    id: 'TNT_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9),
                    ...tenantData,
                    amountPaid: 0,
                    paymentHistory: [],
                    createdAt: new Date().toISOString(),
                    status: 'active'
                };
                this.data.tenants.push(tenant);
                this.save();
                return tenant;
            }

            updateTenant(id, updates) {
                const index = this.data.tenants.findIndex(t => t.id === id);
                if (index !== -1) {
                    this.data.tenants[index] = { ...this.data.tenants[index], ...updates };
                    this.save();
                    return true;
                }
                return false;
            }

            deleteTenant(id) {
                const index = this.data.tenants.findIndex(t => t.id === id);
                if (index !== -1) {
                    this.data.tenants.splice(index, 1);
                    this.save();
                    return true;
                }
                return false;
            }

            addPayment(paymentData) {
                const payment = {
                    id: 'PAY_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9),
                    ...paymentData,
                    createdAt: new Date().toISOString()
                };
                this.data.payments.push(payment);
                
                const tenant = this.getTenant(payment.tenantId);
                if (tenant) {
                    tenant.amountPaid = (tenant.amountPaid || 0) + payment.amount;
                    tenant.paymentHistory.push(payment.id);
                    this.updateTenant(tenant.id, { amountPaid: tenant.amountPaid });
                }
                
                this.save();
                return payment;
            }

            getStatistics() {
                const tenants = this.getTenants();
                const payments = this.getPayments();
                
                const totalRent = tenants.reduce((sum, t) => sum + (t.monthlyRent || 0), 0);
                const totalPaid = payments.reduce((sum, p) => sum + (p.amount || 0), 0);
                const totalDue = totalRent - totalPaid;
                
                const paidTenants = tenants.filter(t => (t.amountPaid || 0) >= (t.monthlyRent || 0)).length;
                const collectionRate = tenants.length > 0 ? (paidTenants / tenants.length) * 100 : 0;
                
                return {
                    totalRent,
                    totalPaid,
                    totalDue,
                    totalTenants: tenants.length,
                    collectionRate: Math.round(collectionRate),
                    paidTenants,
                    pendingTenants: tenants.length - paidTenants
                };
            }
        }

        // Initialize database
        const db = new EnterpriseDB();

        // ========== EMAIL VALIDATION FUNCTION ==========
        function isValidEmail(email) {
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            return emailRegex.test(email);
        }

        // ========== HASH PASSWORD FUNCTION ==========
        async function hashPassword(password) {
            const msgBuffer = new TextEncoder().encode(password);
            const hashBuffer = await crypto.subtle.digest('SHA-256', msgBuffer);
            const hashArray = Array.from(new Uint8Array(hashBuffer));
            return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
        }

        // Session management
        let currentUser = null;
        let sessionTimeout;

        function checkSession() {
            try {
                const session = sessionStorage.getItem('flathub_session');
                if (session) {
                    const sessionData = JSON.parse(session);
                    const sessionAge = Date.now() - sessionData.loginTime;
                    
                    if (sessionAge < 24 * 60 * 60 * 1000) {
                        currentUser = sessionData.email;
                        showDashboard();
                        startSessionTimer();
                        return true;
                    } else {
                        sessionStorage.removeItem('flathub_session');
                    }
                }
            } catch (error) {
                console.error('Session check error:', error);
            }
            return false;
        }

        function startSessionTimer() {
            if (sessionTimeout) clearTimeout(sessionTimeout);
            sessionTimeout = setTimeout(() => {
                Swal.fire({
                    icon: 'warning',
                    title: 'Session Expired',
                    text: 'Your session has expired. Please login again.',
                    timer: 3000
                }).then(() => {
                    logout();
                });
            }, 23 * 60 * 60 * 1000);
        }

        // UI initialization
        document.addEventListener('DOMContentLoaded', function() {
            setTimeout(() => {
                document.getElementById('loader').style.opacity = '0';
                setTimeout(() => {
                    document.getElementById('loader').style.display = 'none';
                }, 500);
            }, 1500);

            if (!checkSession()) {
                document.getElementById('loginPage').style.display = 'flex';
            }

            const today = new Date().toISOString().split('T')[0];
            document.getElementById('receiptDate').value = today;
            document.getElementById('dueDate').value = today;
            
            const options = { year: 'numeric', month: 'long', day: 'numeric' };
            document.getElementById('receiptDateDisplay').textContent = 
                new Date().toLocaleDateString('en-IN', options);
        });

        // Login mode toggle
        let isLoginMode = true;

        document.getElementById('toggleMode').addEventListener('click', function() {
            isLoginMode = !isLoginMode;
            const loginBtn = document.getElementById('loginBtn');
            const loginText = document.getElementById('loginText');
            
            if (isLoginMode) {
                this.textContent = 'Create New Account';
                loginText.textContent = 'Login to Dashboard';
            } else {
                this.textContent = 'Already have an account? Login';
                loginText.textContent = 'Create Admin Account';
            }
        });

        // Login button click
        document.getElementById('loginBtn').addEventListener('click', handleAuth);
        
        // Enter key press
        document.getElementById('password').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') handleAuth();
        });

        // Main authentication function
       async function handleAuth() {
    const email = document.getElementById('email').value.trim();
    const password = document.getElementById('password').value.trim();
    const loginBtn = document.getElementById('loginBtn');
    const loginText = document.getElementById('loginText');
    const loginSpinner = document.getElementById('loginSpinner');

    // Basic Validation
    if (!email || !password) {
        Swal.fire({ icon: 'error', title: 'Missing Info', text: 'Please enter both email and password' });
        return;
    }

    // Show Loading UI
    loginBtn.disabled = true;
    if(loginText) loginText.style.display = 'none';
    if(loginSpinner) loginSpinner.style.display = 'inline-block';

    try {
        // Database se admin records lein
        const admin = db.getAdmin();
        
        // Demo Check: Agar database naya hai toh plain text match karein, 
        // warna hashed password match karein
        const inputHashed = await hashPassword(password);
        
        const isDefaultAdmin = (email === 'admin@flathub.com' && password === 'admin123');
        const isMatchingRecord = (admin && email === admin.email && (inputHashed === admin.password || password === admin.password));

        if (isDefaultAdmin || isMatchingRecord) {
            // Login Success logic
            currentUser = email;
            db.updateLastLogin();
            
            sessionStorage.setItem('flathub_session', JSON.stringify({
                email: email,
                loginTime: Date.now()
            }));
            
            await Swal.fire({
                icon: 'success',
                title: 'Access Granted',
                text: 'Welcome to FlatHub Enterprise',
                timer: 1500,
                showConfirmButton: false
            });
            
            showDashboard();
        } else {
            // Login Fail logic
            Swal.fire({
                icon: 'error',
                title: 'Invalid Credentials',
                text: 'The email or password you entered is incorrect.'
            });
        }
    } catch (error) {
        console.error('Auth Error:', error);
        Swal.fire({ icon: 'error', title: 'System Error', text: 'Something went wrong. Please refresh.' });
    } finally {
        // Reset Button UI
        loginBtn.disabled = false;
        if(loginText) loginText.style.display = 'inline';
        if(loginSpinner) loginSpinner.style.display = 'none';
    }
}
        function showDashboard() {
            document.getElementById('loginPage').style.display = 'none';
            document.getElementById('dashboard').style.display = 'block';
            document.getElementById('appWrapper').classList.add('visible');
            
            document.getElementById('userEmail').textContent = currentUser;
            document.getElementById('profileEmail').value = currentUser;
            document.getElementById('userAvatar').textContent = currentUser.charAt(0).toUpperCase();
            
            loadDashboardData();
            loadAllTenants();
            loadPayments();
            
            startSessionTimer();
        }

        // Dashboard functions
        function loadDashboardData() {
            const stats = db.getStatistics();
            
            document.getElementById('totalRevenue').textContent = stats.totalPaid.toLocaleString();
            document.getElementById('pendingDues').textContent = stats.totalDue.toLocaleString();
            document.getElementById('pendingCount').textContent = stats.pendingTenants;
            document.getElementById('totalTenants').textContent = stats.totalTenants;
            document.getElementById('collectionRate').textContent = stats.collectionRate;

            const tenants = db.getTenants();
            const recentTbody = document.getElementById('recentTenantsTable');
            recentTbody.innerHTML = '';
            
            tenants.slice(0, 5).forEach(tenant => {
                const due = tenant.monthlyRent - (tenant.amountPaid || 0);
                const status = due <= 0 ? 'Paid' : due > tenant.monthlyRent ? 'Overdue' : 'Pending';
                const statusClass = due <= 0 ? 'status-paid' : due > tenant.monthlyRent ? 'status-overdue' : 'status-pending';
                
                recentTbody.innerHTML += `
                    <tr>
                        <td>${tenant.name}</td>
                        <td>${tenant.flatNumber}</td>
                        <td>₹${tenant.monthlyRent.toLocaleString()}</td>
                        <td>₹${(tenant.amountPaid || 0).toLocaleString()}</td>
                        <td>₹${Math.max(0, due).toLocaleString()}</td>
                        <td><span class="status-badge ${statusClass}">${status}</span></td>
                        <td>
                            <div class="action-btns">
                                <button class="action-btn" onclick="viewTenant('${tenant.id}')" title="View">
                                    <i class="fas fa-eye"></i>
                                </button>
                                <button class="action-btn" onclick="recordPayment('${tenant.id}')" title="Record Payment">
                                    <i class="fas fa-rupee-sign"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                `;
            });

            if (tenants.length === 0) {
                recentTbody.innerHTML = '<tr><td colspan="7" style="text-align: center;">No tenants found</td></tr>';
            }
        }

        function loadAllTenants() {
            const tenants = db.getTenants();
            const tbody = document.getElementById('allTenantsTable');
            
            tbody.innerHTML = '';
            
            tenants.forEach(tenant => {
                const due = tenant.monthlyRent - (tenant.amountPaid || 0);
                const status = due <= 0 ? 'Paid' : due > tenant.monthlyRent ? 'Overdue' : 'Pending';
                const statusClass = due <= 0 ? 'status-paid' : due > tenant.monthlyRent ? 'status-overdue' : 'status-pending';
                
                tbody.innerHTML += `
                    <tr>
                        <td>${tenant.name}</td>
                        <td>${tenant.phone}<br><small>${tenant.email}</small></td>
                        <td>${tenant.flatNumber}</td>
                        <td>₹${tenant.monthlyRent.toLocaleString()}</td>
                        <td>₹${(tenant.amountPaid || 0).toLocaleString()}</td>
                        <td>₹${Math.max(0, due).toLocaleString()}</td>
                        <td><span class="status-badge ${statusClass}">${status}</span></td>
                        <td>
                            <div class="action-btns">
                                <button class="action-btn" onclick="viewTenant('${tenant.id}')" title="View">
                                    <i class="fas fa-eye"></i>
                                </button>
                                <button class="action-btn" onclick="recordPayment('${tenant.id}')" title="Record Payment">
                                    <i class="fas fa-rupee-sign"></i>
                                </button>
                                <button class="action-btn" onclick="editTenant('${tenant.id}')" title="Edit">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="action-btn" onclick="deleteTenant('${tenant.id}')" title="Delete">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                `;
            });

            if (tenants.length === 0) {
                tbody.innerHTML = '<tr><td colspan="8" style="text-align: center;">No tenants found</td></tr>';
            }
        }

        function loadPayments() {
            const payments = db.getPayments();
            const tbody = document.getElementById('paymentsTable');
            
            tbody.innerHTML = '';
            
            payments.sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt)).forEach(payment => {
                const date = new Date(payment.createdAt);
                
                tbody.innerHTML += `
                    <tr>
                        <td>${date.toLocaleDateString('en-IN')}</td>
                        <td>${payment.tenantName}</td>
                        <td>${db.getTenant(payment.tenantId)?.flatNumber || '-'}</td>
                        <td>₹${payment.amount.toLocaleString()}</td>
                        <td>${payment.method}</td>
                        <td><span class="status-badge status-paid">Completed</span></td>
                        <td>
                            <button class="action-btn" onclick="generateReceiptForPayment('${payment.id}')">
                                <i class="fas fa-receipt"></i>
                            </button>
                        </td>
                    </tr>
                `;
            });

            if (payments.length === 0) {
                tbody.innerHTML = '<tr><td colspan="7" style="text-align: center;">No payments recorded</td></tr>';
            }
        }

        // Tab switching
        window.switchTab = function(tabName) {
            document.querySelectorAll('.nav-tab').forEach(tab => {
                tab.classList.remove('active');
            });
            event.target.closest('.nav-tab').classList.add('active');

            document.querySelectorAll('.tab-content').forEach(content => {
                content.classList.remove('active');
            });
            document.getElementById(tabName + 'Tab').classList.add('active');

            if (tabName === 'dashboard') {
                loadDashboardData();
            } else if (tabName === 'tenants') {
                loadAllTenants();
            } else if (tabName === 'payments') {
                loadPayments();
            }
        };

        // Other functions (minimal implementations)
        window.viewTenant = function(id) { 
            const tenant = db.getTenant(id);
            if (tenant) {
                Swal.fire({
                    title: tenant.name,
                    html: `
                        <p>Email: ${tenant.email}</p>
                        <p>Phone: ${tenant.phone}</p>
                        <p>Flat: ${tenant.flatNumber}</p>
                        <p>Rent: ₹${tenant.monthlyRent}</p>
                    `
                });
            }
        };

        window.recordPayment = function(id) {
            const tenant = db.getTenant(id);
            if (!tenant) return;

            Swal.fire({
                title: 'Record Payment',
                input: 'number',
                inputLabel: `Amount (Monthly Rent: ₹${tenant.monthlyRent})`,
                showCancelButton: true,
                confirmButtonText: 'Record'
            }).then((result) => {
                if (result.isConfirmed && result.value) {
                    db.addPayment({
                        tenantId: tenant.id,
                        tenantName: tenant.name,
                        amount: parseFloat(result.value),
                        method: 'Cash'
                    });
                    Swal.fire('Success', 'Payment recorded', 'success');
                    loadDashboardData();
                    loadAllTenants();
                    loadPayments();
                }
            });
        };

        window.editTenant = function(id) {
            const tenant = db.getTenant(id);
            if (!tenant) return;
            
            Swal.fire({
                title: 'Edit Tenant',
                html: `
                    <input id="editName" class="swal2-input" value="${tenant.name}">
                    <input id="editEmail" class="swal2-input" value="${tenant.email}">
                `,
                showCancelButton: true,
                confirmButtonText: 'Update'
            }).then((result) => {
                if (result.isConfirmed) {
                    db.updateTenant(id, {
                        name: document.getElementById('editName').value,
                        email: document.getElementById('editEmail').value
                    });
                    loadAllTenants();
                }
            });
        };

        window.deleteTenant = function(id) {
            Swal.fire({
                title: 'Delete Tenant?',
                text: "This action cannot be undone!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef233c',
                confirmButtonText: 'Delete'
            }).then((result) => {
                if (result.isConfirmed) {
                    db.deleteTenant(id);
                    loadAllTenants();
                    loadDashboardData();
                }
            });
        };

        window.addTenant = function() {
            const name = document.getElementById('tenantName').value;
            const email = document.getElementById('tenantEmail').value;
            const phone = document.getElementById('tenantPhone').value;
            const flat = document.getElementById('flatNumber').value;
            const rent = parseFloat(document.getElementById('monthlyRent').value);

            if (!name || !email || !phone || !flat || !rent) {
                Swal.fire('Error', 'Please fill all fields', 'error');
                return;
            }

            db.addTenant({ name, email, phone, flatNumber: flat, monthlyRent: rent });
            Swal.fire('Success', 'Tenant added', 'success');
            
            document.getElementById('tenantName').value = '';
            document.getElementById('tenantEmail').value = '';
            document.getElementById('tenantPhone').value = '';
            document.getElementById('flatNumber').value = '';
            document.getElementById('monthlyRent').value = '';
            
            loadAllTenants();
            loadDashboardData();
        };

