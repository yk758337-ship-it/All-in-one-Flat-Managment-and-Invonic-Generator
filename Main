            const tenants = db.getTenants();
            const filtered = tenants.filter(t => 
                t.name.toLowerCase().includes(searchTerm) ||
                t.phone.includes(searchTerm) ||
                t.flatNumber.toLowerCase().includes(searchTerm)
            );
            
            const tbody = document.getElementById('allTenantsTable');
            tbody.innerHTML = '';
            
            filtered.forEach(tenant => {
                const due = tenant.monthlyRent - (tenant.amountPaid || 0);
                const status = due <= 0 ? 'Paid' : due > tenant.monthlyRent ? 'Overdue' : 'Pending';
                const statusClass = due <= 0 ? 'status-paid' : due > tenant.monthlyRent ? 'status-overdue' : 'status-pending';
                
                tbody.innerHTML += `
                    <tr>
                        <td>${tenant.name}</td>
                        <td>${tenant.phone}<br><small>${tenant.email}</small></td>
                        <td>${tenant.flatNumber}</td>
                        <td>₹${tenant.monthlyRent.toLocaleString()}</td>
                        <td>₹${(tenant.amountPaid || 0).toLocaleString()}</td>
                        <td>₹${Math.max(0, due).toLocaleString()}</td>
                        <td><span class="status-badge ${statusClass}">${status}</span></td>
                        <td>
                            <div class="action-btns">
                                <button class="action-btn" onclick="viewTenant('${tenant.id}')" title="View">
                                    <i class="fas fa-eye"></i>
                                </button>
                                <button class="action-btn" onclick="recordPayment('${tenant.id}')" title="Record Payment">
                                    <i class="fas fa-rupee-sign"></i>
                                </button>
                                <button class="action-btn" onclick="editTenant('${tenant.id}')" title="Edit">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="action-btn" onclick="deleteTenant('${tenant.id}')" title="Delete">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                `;
            });
        });
